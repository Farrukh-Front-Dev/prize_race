# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prizerace:password@localhost:5432/prizerace
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── Tarantool ─────────────────────────────────────────────────────────────────
TARANTOOL_HOST=localhost
TARANTOOL_PORT=3301

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC-your-bot-token-here
TELEGRAM_WEBHOOK_SECRET=change_me_random_string_32_chars

# ── TON blockchain ────────────────────────────────────────────────────────────
TON_NETWORK=testnet
TON_API_KEY=your_toncenter_api_key_here
TON_CONTRACT_ADDRESS=EQC_your_smart_contract_address_here

# ── App ───────────────────────────────────────────────────────────────────────
# DEBUG=true  →  enables /docs, /redoc, X-Test-Telegram-Id bypass
# DEBUG=false →  production mode, Alembic manages schema
DEBUG=true
SECRET_KEY=change_me_64_char_random_string_here

# ── Anti-fraud ────────────────────────────────────────────────────────────────
MIN_ACCOUNT_AGE_DAYS=30
MAX_DAILY_REFERRALS=20

# ── Background sync worker (Tarantool → PostgreSQL) ───────────────────────────
SYNC_INTERVAL_SECONDS=5
SYNC_BATCH_SIZE=100
